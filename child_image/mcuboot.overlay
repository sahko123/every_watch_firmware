/*
 * MCUboot DTS overlay for Every Watch.
 *
 * Strip sensor/peripheral nodes that conflict with MCUboot's Kconfig
 * (frtc8900 selects RTC_ALARM; bmi270 pulls in SPI sensor deps, etc.).
 * Declare mcuboot-button0 so the serial recovery entrance GPIO driver
 * can find the left button via DT_ALIAS(mcuboot_button0).
 */

/ {
	chosen {
		/delete-property/ zephyr,uart-mcumgr;
	};

	aliases {
		/delete-property/ rtc0;
		/delete-property/ batt0;
		/delete-property/ light0;
		/* Left button (P0.17, active-low) triggers CDC-ACM serial recovery */
		mcuboot-button0 = &button_left;
	};
};

&i2c0 {
	/delete-node/ frtc8900@32;
	/delete-node/ bmi270@68;
	/delete-node/ bh1750@23;
	/delete-node/ bq27441@55;
};

/* USB stays enabled — MCUboot uses it for CDC-ACM serial recovery mode */
