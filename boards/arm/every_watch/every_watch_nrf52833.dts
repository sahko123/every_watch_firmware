/dts-v1/;
#include <nordic/nrf52833_qdaa.dtsi>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/i2c/i2c.h>
#include "every_watch_nrf52833-pinctrl.dtsi"

/ {
	model = "Every Watch";
	compatible = "everywatch,every-watch-nrf52833";

	chosen {
		zephyr,sram           = &sram0;
		zephyr,flash          = &flash0;
		zephyr,code-partition = &slot0_partition;
		/* DFU: MCUboot USB DFU WAIT mode — hold left button 3 s in app to
		 * reboot into bootloader, then:
		 *   dfu-util -d 2fe3:0100 -a 0 -D build/zephyr/app_update.bin */
	};

	/* ── Buttons ─────────────────────────────────────────────────────── */
	buttons {
		compatible = "gpio-keys";

		button_left: button_left {
			gpios = <&gpio0 17 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			label = "Left button";
		};

		button_right: button_right {
			gpios = <&gpio0 15 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			label = "Right button";
		};
	};

	/* ── Charge / battery GPIOs (input only at this stage) ───────────── */
	gpio_inputs {
		compatible = "gpio-keys";

		/* SGM41524 charge indicator — active low */
		chg_indicator: chg_indicator {
			gpios = <&gpio0 5 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			label = "Charge indicator";
		};

		/* BQ27441 GPOUT / battery monitor interrupt — open-drain output,
		 * pull-up required (no PCB resistor assumed). */
		batt_gpout: batt_gpout {
			gpios = <&gpio1 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
			label = "Battery GPOUT";
		};
	};

	aliases {
		btn-left  = &button_left;
		btn-right = &button_right;
		rtc0      = &frtc8900;
		batt0     = &bq27441;
		light0    = &bh1750;
	};
};

/* ── Flash partitions ────────────────────────────────────────────────── */
/* nRF52833: 512 KB flash (0x00000000 – 0x0007FFFF)
 *
 *   MCUboot  :  48 KB  0x00000000 – 0x0000BFFF  (USB DFU WAIT mode)
 *   Slot 0   : 448 KB  0x0000C000 – 0x0007BFFF  (single image slot, no slot 1)
 *   Identity :   8 KB  0x0007C000 – 0x0007DFFF  (encounter hashes, enc_count — NVS)
 *   Settings :   8 KB  0x0007E000 – 0x0007FFFF  (Zephyr Settings / BT bond keys)
 *
 * Single-slot: hold left button 3 s -> app reboots -> MCUboot opens 5 s USB
 * DFU window -> dfu-util -d 2fe3:0100 -a 0 -D build/zephyr/app_update.bin
 * Matches pm_static.yml. */
&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 0xC000>;
			read-only;
		};

		slot0_partition: partition@C000 {
			label = "image-0";
			reg = <0x0000C000 0x70000>;
		};

		identity_partition: partition@7C000 {
			label = "identity_partition";
			reg = <0x0007C000 0x2000>;
		};

		/* Zephyr Settings backend (BT bond keys); matches pm_static.yml nvs_storage */
		storage_partition: partition@7E000 {
			label = "storage";
			reg = <0x0007E000 0x2000>;
		};
	};
};

/* ── I2C0 — all on-board sensors ─────────────────────────────────────── */
&i2c0 {
	compatible = "nordic,nrf-twim";
	status = "okay";
	pinctrl-0 = <&i2c0_default>;
	pinctrl-1 = <&i2c0_sleep>;
	pinctrl-names = "default", "sleep";
	clock-frequency = <I2C_BITRATE_FAST>;

	frtc8900: frtc8900@32 {
		compatible = "nyfea,frtc8900";
		reg = <0x32>;
		/* /INT: open-drain, active low — GPIO pull-up required */
		int-gpios = <&gpio0 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
	};

	bmi270: bmi270@68 {
		compatible = "bosch,bmi270";
		reg = <0x68>;
		irq-gpios = <&gpio0 30 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
		            <&gpio0 31 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
	};

	bh1750: bh1750@23 {
		compatible = "rohm,bh1750";
		reg = <0x23>;
	};

	bq27441: bq27441@55 {
		compatible = "ti,bq274xx";
		reg = <0x55>;
		/* IMPORTANT: set design-capacity to match the actual battery cell (mAh).
		 * Wrong value causes inaccurate state-of-charge readings from BQ27441.
		 * Check the battery datasheet and update before shipping. */
		design-capacity = <300>;
		design-voltage = <3700>;   /* mV nominal */
		taper-current = <45>;      /* mA */
		terminate-voltage = <3000>; /* mV cutoff */
	};
};

/* ── SPI peripherals — WS2812B LED matrix ───────────────────────────── */
/* WS2812B 3-bit encoding at 2 MHz: each LED bit → 3 SPI bits, 500 ns each.
 * SPIM1, SPIM2, SPIM3 fire in parallel via async DMA for rows 0-5.
 * Row 6 (P0.03) uses bitbang — see led_matrix.c.
 * SPI0 is disabled: SPIM0 and TWIM0 share hardware at 0x40003000. */

&spi0 {
	status = "disabled";
};

&spi1 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	pinctrl-0 = <&spi1_default>;
	pinctrl-1 = <&spi1_sleep>;
	pinctrl-names = "default", "sleep";
	clock-frequency = <DT_FREQ_M(2)>;
};

&spi2 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	pinctrl-0 = <&spi2_default>;
	pinctrl-1 = <&spi2_sleep>;
	pinctrl-names = "default", "sleep";
	clock-frequency = <DT_FREQ_M(2)>;
};

&spi3 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	pinctrl-0 = <&spi3_default>;
	pinctrl-1 = <&spi3_sleep>;
	pinctrl-names = "default", "sleep";
	clock-frequency = <DT_FREQ_M(2)>;
};

/* ── GPIO ports ──────────────────────────────────────────────────────── */
&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&gpiote {
	status = "okay";
};

/* ── Low-frequency clock ─────────────────────────────────────────────── */
/* TODO: verify a 32.768 kHz crystal is populated on the PCB, then enable:
 *   &clock { lf-clk-src = <1>; };   (1 = XTAL, 0 = RC)
 * Without XTAL, BLE timing uses the internal RC oscillator (±250 ppm vs
 * ±20–50 ppm for crystal), increasing power consumption on connection retries. */

/* ── USB — MCUboot USB DFU WAIT mode ─────────────────────────────────── */
/* nRF52833 USBD uses dedicated D+/D- pins; VBUS detected via POWER
 * peripheral events — no GPIO VBUS pin needed.
 * cdc_acm_uart0 kept for MCUboot's USB DFU class enumeration. */
zephyr_udc0: &usbd {
	status = "okay";
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};
