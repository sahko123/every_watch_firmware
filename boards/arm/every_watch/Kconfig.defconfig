if BOARD_EVERY_WATCH

config HW_STACK_PROTECTION
	default ARCH_HAS_STACK_PROTECTION

# NCS SoC-level Kconfig selects the SoftDevice Controller (SDC) for nRF52833
# automatically. Do not set BT_CTLR here — it would be a no-op and the
# SDC, not Zephyr's software LL, is always used on this SoC in NCS builds.

endif # BOARD_EVERY_WATCH
